FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=bookms-dev-secret

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=bookms

# 前端开发地址（逗号分隔），用于携带 Cookie 的跨域请求
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 生产环境 HTTPS 下可设为 true，并配合 SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
